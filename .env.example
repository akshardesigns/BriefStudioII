# Copy these into Vercel Dashboard → Project → Settings → Environment Variables
# (jangan pernah commit file .env asli yang isinya sudah terisi ke Git!)

# JSON lengkap dari Firebase Console > Project Settings > Service accounts >
# Generate new private key — paste sebagai SATU baris string JSON.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"briefstudio", ...}

# Firebase Console > Project Settings > General > Web API Key
FIREBASE_WEB_API_KEY=AIzaSyB_v6I9trCeGQigOzQZoOm57818lVt6HPw

# Secret yang sama dengan yang kamu set di Lynk.id > Settings > Integrations > Webhooks
LYNK_WEBHOOK_SECRET=isi-dengan-secret-dari-dashboard-lynk

# Nama header signature yang dipakai Lynk.id (cek dokumentasi/dashboard-mu; default x-signature)
LYNK_SIGNATURE_HEADER=x-signature

# Filter produk: hanya request dengan judul/ID produk yang match ini yang akan
# diproses (karena Lynk.id-mu ada produk lain juga). Pisahkan dengan koma.
LYNK_PRODUCT_MATCH=AdsBrief Studio

# URL app kamu, supaya link "set password" mengarahkan balik ke sini setelah selesai
APP_URL=https://your-project.vercel.app
